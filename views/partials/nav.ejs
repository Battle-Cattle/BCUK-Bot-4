<nav class="navbar">
  <a href="/" class="navbar-brand">🤖 BCUK Bot</a>
  <div class="navbar-menu">
    <a href="/" class="nav-item">Dashboard</a>
    <% if (user && user.accessLevel >= 2) { %>
    <a href="/admin/users" class="nav-item">Users</a>
    <a href="/admin/streams" class="nav-item">Streams</a>
    <% } %>
  </div>
  <div class="navbar-end">
    <% if (user) { %>
    <% if (user.discordAvatar) { %>
    <img src="<%= user.discordAvatar %>?size=32" class="avatar" alt="">
    <% } %>
    <span class="username"><%= user.discordName %></span>
    <span class="badge level-<%= user.accessLevel %>"><%= ['User','Mod','Manager','Admin'][user.accessLevel] || 'Unknown' %></span>
    <a href="/auth/logout" class="btn btn-ghost btn-sm">Logout</a>
    <% } %>
  </div>
</nav>
