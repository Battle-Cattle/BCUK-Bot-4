<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BCUK Bot — Users</title>
  <link rel="stylesheet" href="/style.css">
  <%- include('partials/pwa-head') %>
</head>
<body>
  <%- include('partials/nav') %>

  <main class="container">
    <section class="section">
      <h2 class="section-title">User Management</h2>

      <% if (error) { %>
      <div class="card card-alert-danger" role="alert" aria-live="assertive" aria-atomic="true">
        <span class="text-danger">&#9888; <%= error === 'duplicate_twitch_name' ? 'Twitch name is already assigned to another user.' : 'Operation failed: ' + error.replace(/_/g, ' ') %></span>
      </div>
      <% } %>

      <% if (refreshState.outcome === 'running') { %>
      <div class="card card-alert-primary" data-refresh-running="true">
        <span class="text-primary">Refreshing Discord names in the background...</span>
      </div>
      <% } else if (refreshState.outcome === 'success') { %>
      <div class="card card-alert-success">
        <span class="text-success">&#10003; Discord names refreshed for <%= refreshState.updatedCount %> user<%= refreshState.updatedCount === 1 ? '' : 's' %>.</span>
      </div>
      <% } else if (refreshState.outcome === 'partial') { %>
      <div class="card card-alert-warning">
        <span class="text-warning">&#9888; Discord names refreshed for <%= refreshState.updatedCount %> user<%= refreshState.updatedCount === 1 ? '' : 's' %>, but <%= refreshState.failureCount %> lookup<%= refreshState.failureCount === 1 ? '' : 's' %> failed.</span>
      </div>
      <% } else if (refreshState.outcome === 'noop') { %>
      <div class="card card-alert-muted">
        <span class="muted">No Discord names needed refreshing.</span>
      </div>
      <% } else if (refreshState.outcome === 'error') { %>
      <div class="card card-alert-danger" role="alert" aria-live="assertive" aria-atomic="true">
        <span class="text-danger">&#9888; Discord name refresh failed<%= refreshState.failureCount > 0 ? ' for ' + refreshState.failureCount + ' user' + (refreshState.failureCount === 1 ? '' : 's') : '' %>.</span>
      </div>
      <% } %>

      <% if (user.accessLevel >= 2) { %>
      <div class="align-right-row">
        <form method="POST" action="/admin/users/refresh-names" class="inline-form-sm">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-sm" <%= refreshState.outcome === 'running' ? 'disabled' : '' %>><%= refreshState.outcome === 'running' ? 'Refreshing...' : 'Refresh Discord Names' %></button>
        </form>
      </div>
      <% } %>

      <!-- Add user (Admin only) -->
      <% if (user.accessLevel >= 3) { %>
      <div class="card card-spaced">
        <div class="card-header"><span class="card-icon">➕</span><span class="card-label">Add / Update User</span></div>
        <form method="POST" action="/admin/users/add" class="inline-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input class="input" type="text" name="discord_id"   placeholder="Discord User ID"  required>
          <input class="input" type="text" name="discord_name" placeholder="Display name (optional)">
          <input class="input" type="text" name="twitch_name" placeholder="Twitch name (optional)" data-twitch-name-input>
          <label class="hint hint-inline-row">
            <input type="checkbox" name="clear_twitch_name" value="1" data-clear-twitch-name-input>
            Clear Twitch name
          </label>
          <select class="input" name="access_level">
            <% Object.entries(accessLevelLabels).forEach(([val, label]) => { %>
            <option value="<%= val %>"><%= label %></option>
            <% }) %>
          </select>
          <button type="submit" class="btn">Add / Update</button>
        </form>
        <p class="hint">Enter the user's Discord numeric ID (right-click user in Discord → Copy User ID with Developer Mode on).</p>
      </div>
      <% } %>

      <!-- User list -->
      <div class="card">
        <div class="table-scroll">
        <table class="table" aria-label="Users">
          <thead>
            <tr>
              <th scope="col">Discord ID</th>
              <th scope="col">Name</th>
              <th scope="col">Twitch</th>
              <th scope="col">Twitch Bot</th>
              <th scope="col">Level</th>
              <% if (user.accessLevel >= 3) { %><th scope="col">Actions</th><% } %>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function(u) { %>
            <tr>
              <td class="mono"><%= u.discord_id %></td>
              <td><%= u.discord_name || '—' %></td>
              <td class="mono"><%= u.twitch_name || '—' %></td>
              <td>
                <% if (u.twitch_name) { %>
                  <div class="twitch-bot-controls">
                    <span class="badge <%= u.is_twitch_bot_enabled ? 'badge-online' : 'badge-offline' %>">
                      <%= u.is_twitch_bot_enabled ? 'Enabled' : 'Disabled' %>
                    </span>
                    <% if (user.accessLevel >= 2) { %>
                    <form method="POST" action="/admin/users/toggle-twitch" class="inline-form-sm">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <input type="hidden" name="discord_id" value="<%= u.discord_id %>">
                      <input type="hidden" name="is_twitch_bot_enabled" value="<%= u.is_twitch_bot_enabled ? 'false' : 'true' %>">
                      <button type="submit" class="btn btn-sm"><%= u.is_twitch_bot_enabled ? 'Disable' : 'Enable' %></button>
                    </form>
                    <% } %>
                  </div>
                <% } else { %>
                  <div class="twitch-bot-controls">
                    <span class="badge badge-offline">Unavailable</span>
                    <% if (user.accessLevel >= 2) { %>
                    <button type="button" class="btn btn-sm btn-disabled-muted" disabled>Set Twitch Name</button>
                    <% } %>
                  </div>
                <% } %>
              </td>
              <td><span class="badge level-<%= u.access_level %>"><%= accessLevelLabels[u.access_level] || u.access_level %></span></td>
              <% if (user.accessLevel >= 3) { %>
              <td>
                <div class="actions">
                <!-- Change level -->
                <form method="POST" action="/admin/users/update" class="inline-form-sm">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="discord_id" value="<%= u.discord_id %>">
                  <select class="input input-sm" name="access_level">
                    <% Object.entries(accessLevelLabels).forEach(([val, label]) => { %>
                    <option value="<%= val %>" <%= parseInt(val) === u.access_level ? 'selected' : '' %>><%= label %></option>
                    <% }) %>
                  </select>
                  <button type="submit" class="btn btn-sm">Set</button>
                </form>
                <!-- Remove -->
                <% if (u.discord_id !== user.discordId) { %>
                <form method="POST" action="/admin/users/remove" class="inline-form-sm js-confirm-remove-user" data-user-name="<%= u.discord_name || u.discord_id %>">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="discord_id" value="<%= u.discord_id %>">
                  <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                </form>
                <% } %>
                </div>
              </td>
              <% } %>
            </tr>
            <% }) %>
            <% if (users.length === 0) { %>
            <tr><td colspan="<%= user.accessLevel >= 3 ? 6 : 5 %>" class="empty-msg">No users in the database.</td></tr>
            <% } %>
          </tbody>
        </table>
        </div>
      </div>
    </section>
  </main>
  <%- include('partials/pwa-register') %>
  <script src="/admin.js"></script>
</body>
</html>
