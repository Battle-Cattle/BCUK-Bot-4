<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BCUK Bot — Command Monitor</title>
  <link rel="stylesheet" href="/style.css">
  <%- include('partials/pwa-head') %>
<%
function htmlAttrJson(value) {
  const replacements = {
    '&': '&amp;',
    '"': '&quot;',
    "'": '&#39;',
    '<': '&lt;',
    '>': '&gt;',
  };

  return JSON.stringify(value).replace(/[&"'<>]/g, function (char) {
    return replacements[char] || char;
  });
}
%>
</head>
<body data-command-monitor-entries='<%- htmlAttrJson(recentEntries) %>'>
  <%- include('partials/nav') %>

  <main class="container">
    <section class="section">
      <h2 class="section-title">Command Monitor</h2>

      <div class="card card-spaced">
        <div class="card-header">
          <span class="card-icon">🧪</span>
          <span class="card-label">Preview Only</span>
        </div>
        <div class="card-body card-body-muted">
          This page shows the most recent custom commands and counter commands detected by this bot for monitoring. Replies are currently suppressed in preview mode, and counter values are not changed here.
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <span class="card-icon">📜</span>
          <span class="card-label">Recent Matches</span>
          <span class="live-updated-meta">Auto-refreshes every 5s</span>
        </div>
        <div class="table-scroll">
          <table class="table" aria-label="Recent command matches">
            <thead>
              <tr>
                <th scope="col">When</th>
                <th scope="col">Source</th>
                <th scope="col">User</th>
                <th scope="col">Channel</th>
                <th scope="col">Command</th>
                <th scope="col">Response Preview</th>
              </tr>
            </thead>
            <tbody id="command-monitor-body">
              <tr id="command-monitor-empty-row">
                <td colspan="6" class="empty-msg">No matching custom commands or counter commands have been seen yet.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/pwa-register') %>
  <script src="/command-monitor.js"></script>
</body>
</html>
