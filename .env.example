# Discord (bot)
DISCORD_GUILD_ID=your_guild_id_here
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_VOICE_CHANNEL_ID=your_voice_channel_id_here

# Discord OAuth application (create at https://discord.com/developers/applications)
# Under OAuth2 -> Redirects, add: http://localhost:3000/auth/discord/callback
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback
DISCORD_CLIENT_ID=your_discord_oauth_app_client_id
DISCORD_CLIENT_SECRET=your_discord_oauth_app_client_secret

# Twitch (chat bot)
# Comma-separated list of channels to listen to
TWITCH_CHANNELS=channel1,channel2
TWITCH_OAUTH_TOKEN=oauth:your_token_here
TWITCH_USERNAME=your_bot_username

# Twitch stream monitor (live announcements in Discord)
# Create an app at https://dev.twitch.tv/console/apps — these are NOT the chat bot OAuth token
TWITCH_CLIENT_ID=your_twitch_app_client_id
TWITCH_CLIENT_SECRET=your_twitch_app_client_secret

# TikTok
# Comma-separated list of TikTok streamer usernames to monitor (@ prefix optional)
TIKTOK_CHANNELS=username1,username2
# Optional: sign API key from https://www.eulerstream.com (improves connection reliability)
# TIKTOK_SIGN_API_KEY=your_key_here

# MySQL Database
DB_HOST=localhost
DB_NAME=your_db_name
DB_PASSWORD=your_db_password
DB_PORT=3306
DB_USER=root

# Bot settings
# Global cooldown in milliseconds between any two sound plays
GLOBAL_COOLDOWN_MS=3000
# Path to the folder containing .mp3/.wav sound files
SFX_FOLDER=./sfx

# Web panel
# Random secret string for signing session cookies — MUST be changed to a long random value
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=__REQUIRED_GENERATE_LONG_RANDOM_SECRET__
WEB_PORT=3000
